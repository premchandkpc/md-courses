    <line class="topo-edge" x1="300" y1="70" x2="460" y2="140" marker-end="url(#arrow1)"/>
    <line class="topo-edge" x1="140" y1="190" x2="290" y2="235" marker-end="url(#arrow1)"/>
    <line class="topo-edge" x1="300" y1="190" x2="300" y2="235" marker-end="url(#arrow1)"/>
    <line class="topo-edge" x1="460" y1="190" x2="310" y2="235" marker-end="url(#arrow1)"/>
  </svg>
  <div class="topo-legend">
    <div class="legend-item"><div class="legend-color" style="background:#1e3a5f;border:1px solid #00d4ff"></div><span>Node</span></div>
    <div class="legend-item"><div class="legend-color" style="background:#1e3a5f;border:1px solid #1e3a5f;height:2px;top:6px;position:relative"></div><span>Connection</span></div>
  </div>
  <script>
    function highlightEdges(e) {
      document.querySelectorAll('.topo-edge').forEach(edge => edge.classList.remove('active'));
    }
  </script>
</div>

