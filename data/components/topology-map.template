<!-- TOPOLOGY MAP TEMPLATE (SVG)
Usage: Copy into markdown as html-live block, customize SVG nodes/edges
Example: Kubernetes cluster with nodes, pods, load balancer
Tech: Pure SVG with HTML5 event handlers, no external dependencies
-->
<div style="padding:16px;background:#0b0e14;border:1px solid #1e2a3a;border-radius:8px">
  <style>
    .topology-title {
      color:#00d4ff;
      font-family:monospace;
      font-size:14px;
      font-weight:bold;
      margin-bottom:12px;
      letter-spacing:1px;
    }
    .topology-svg {
      width:100%;
      max-width:600px;
      height:300px;
      background:#1a2332;
      border:1px solid #1e3a5f;
      border-radius:4px;
    }
    .topo-node {
      transition:all 0.2s;
      cursor:pointer;
    }
    .topo-node:hover rect,
    .topo-node:hover circle {
      filter:brightness(1.3);
      stroke-width:2;
    }
    .topo-node text {
      pointer-events:none;
    }
    .topo-edge {
      stroke:#1e3a5f;
      stroke-width:2;
    }
    .topo-edge.active {
      stroke:#00d4ff;
      opacity:0.8;
    }
    .topo-legend {
      display:flex;
      gap:16px;
      margin-top:12px;
      font-size:12px;
      color:#e3eaf0;
      font-family:monospace;
      flex-wrap:wrap;
    }
    .legend-item {
      display:flex;
      align-items:center;
      gap:6px;
    }
    .legend-color {
      width:16px;
      height:16px;
      border-radius:2px;
    }
  </style>

  <div class="topology-title">{{TITLE}}</div>
  <svg class="topology-svg" viewBox="0 0 600 300">
    <defs>
      <marker id="arrowhead" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
        <polygon points="0 0, 10 3, 0 6" fill="#1e3a5f"/>
      </marker>
      <marker id="arrowhead-active" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
        <polygon points="0 0, 10 3, 0 6" fill="#00d4ff"/>
      </marker>
    </defs>
    {{SVG_CONTENT}}
  </svg>
  <div class="topo-legend">
    {{LEGEND}}
  </div>
</div>

