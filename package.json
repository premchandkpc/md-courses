{
  "name": "md-courses",
  "version": "1.0.0",
  "private": true,
  "description": "Engineering Knowledge Universe — Interactive learning platform for distributed systems, cloud, AI/ML, and more",
  "type": "commonjs",
  "workspaces": [
    "packages/api-server",
    "packages/legacy-viewer",
    "packages/python-server",
    "packages/react-frontend"
  ],
  "scripts": {
    "start": "node packages/api-server/server.js",
    "serve": "node packages/api-server/server.js 3000",
    "dev": "node packages/api-server/server.js 8080",
    "frontend": "npm run dev -w packages/react-frontend",
    "frontend:build": "npm run build -w packages/react-frontend",
    "frontend:typecheck": "npm run typecheck -w packages/react-frontend",
    "viz": "echo 'Starting API server + frontend...' && node packages/api-server/server.js 3000 & npm run dev -w packages/react-frontend"
  },
  "keywords": [
    "engineering",
    "knowledge",
    "distributed-systems",
    "cloud",
    "ai-ml",
    "backend",
    "devops",
    "system-design"
  ],
  "author": "Engineering Knowledge Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/md-courses"
  },
  "bugs": {
    "url": "https://github.com/yourusername/md-courses/issues"
  },
  "homepage": "http://localhost:3000"
}
